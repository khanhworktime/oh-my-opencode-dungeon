# ── Server ───────────────────────────────────────────────────────────────────
# Port the server listens on
PORT=3000

# Session signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=here

# ── Optional: MySQL / TiDB ───────────────────────────────────────────────────
# Leave blank to run without a database (in-memory + file persistence only)
# DATABASE_URL=mysql://user:password@host:3306/claude_dungeon

# ── Optional: Manus OAuth (leave blank to disable auth) ──────────────────────
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
